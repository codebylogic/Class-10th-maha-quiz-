{
  "plugin": "org.smartide.plugin.web",
  "run": "npx http-server -a localhost -p 8080 -o /011.html",
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "sh -c 'vscode-json-language-server --stdio'"
    },
    ".js": {
      "enabled": true,
      "run": "sh -c 'typescript-language-server --stdio'"
    },
    ".css": {
      "enabled": true,
      "run": "sh -c 'vscode-css-language-server --stdio'"
    },
    ".html": {
      "enabled": false,
      "run": "vscode-html-language-server --stdio"
    }
  }
}